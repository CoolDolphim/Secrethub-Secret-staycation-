local UIS = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local Players = game:GetService("Players")

local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local root = character:WaitForChild("HumanoidRootPart")
local camera = workspace.CurrentCamera

local flying = true
local speed = 120

local moveDir = Vector3.zero

-- FIXED directions
local keyMap = {
	[Enum.KeyCode.W] = Vector3.new(0,0,1),
	[Enum.KeyCode.S] = Vector3.new(0,0,-1),
	[Enum.KeyCode.A] = Vector3.new(-1,0,0),
	[Enum.KeyCode.D] = Vector3.new(1,0,0),
	[Enum.KeyCode.Space] = Vector3.new(0,10,0),
	[Enum.KeyCode.LeftControl] = Vector3.new(0,-1,0),
}

UIS.InputBegan:Connect(function(input, processed)
	if processed then return end
	
	if input.KeyCode == Enum.KeyCode.F then
		flying = not flying
	end
	
	if keyMap[input.KeyCode] then
		moveDir += keyMap[input.KeyCode]
	end
end)

UIS.InputEnded:Connect(function(input)
	if keyMap[input.KeyCode] then
		moveDir -= keyMap[input.KeyCode]
	end
end)

-- 📱 MOBILE UI
if UIS.TouchEnabled then
	local gui = Instance.new("ScreenGui", player:WaitForChild("PlayerGui"))
	gui.Name = "FlyUI"

	-- Toggle button
	local toggle = Instance.new("TextButton", gui)
	toggle.Size = UDim2.new(0,120,0,50)
	toggle.Position = UDim2.new(0,20,1,-70)
	toggle.Text = "FLY"
	toggle.BackgroundColor3 = Color3.fromRGB(40,40,40)
	toggle.TextColor3 = Color3.new(1,1,1)

	toggle.MouseButton1Click:Connect(function()
		flying = not flying
	end)

	-- Up button
	local up = Instance.new("TextButton", gui)
	up.Size = UDim2.new(0,60,0,60)
	up.Position = UDim2.new(1,-80,1,-140)
	up.Text = "↑"

	-- Down button
	local down = Instance.new("TextButton", gui)
	down.Size = UDim2.new(0,60,0,60)
	down.Position = UDim2.new(1,-80,1,-70)
	down.Text = "↓"

	local upHeld = false
	local downHeld = false

	up.MouseButton1Down:Connect(function() upHeld = true end)
	up.MouseButton1Up:Connect(function() upHeld = false end)

	down.MouseButton1Down:Connect(function() downHeld = true end)
	down.MouseButton1Up:Connect(function() downHeld = false end)

	RunService.RenderStepped:Connect(function()
		if upHeld then
			moveDir += Vector3.new(0,1,0)
		end
		if downHeld then
			moveDir += Vector3.new(0,-1,0)
		end
	end)
end

-- 🚀 FLIGHT LOOP
RunService.RenderStepped:Connect(function(dt)
	if not flying or not root then return end
	
	local camCF = camera.CFrame
	
	local direction =
		(camCF.LookVector * moveDir.Z) +
		(camCF.RightVector * moveDir.X) +
		(Vector3.new(0,1,0) * moveDir.Y)

	if direction.Magnitude > 0 then
		direction = direction.Unit
		
		local newPos = root.Position + direction * speed * dt
		root.CFrame = CFrame.new(newPos, newPos + camCF.LookVector)
	end
end)
